{
  "id": "jira",
  "name": "Jira",
  "category": "issue-tracking",
  "descriptor_version": "1.0.0",
  "transport": "mcp",
  "auth_mode": "token",
  "status": "available",
  "summary": "Search issues, read/comment/transition tickets, manage sprints (also covers Confluence).",
  "secrets": [
    { "env": "ATLASSIAN_URL", "label": "Site URL", "required": true, "placeholder": "https://your-team.atlassian.net" },
    { "env": "ATLASSIAN_EMAIL", "label": "Account email", "required": true, "placeholder": "you@company.com" },
    { "env": "ATLASSIAN_API_TOKEN", "label": "API token", "required": true, "placeholder": "ATATT…" }
  ],
  "scopes": ["read:jira-work", "write:jira-work"],
  "scopes_advisory": true,
  "team_instance": [
    { "env": "ATLASSIAN_URL", "label": "Jira site URL", "placeholder": "https://your-team.atlassian.net" }
  ],
  "docs": {
    "token_create_url": "https://id.atlassian.com/manage-profile/security/api-tokens",
    "scopes_url": "https://developer.atlassian.com/cloud/jira/platform/scopes-for-oauth-2-3LO-and-forge-apps/",
    "instructions": "Create an API token at id.atlassian.com → Security → API tokens. Use your Atlassian account email and your site URL (https://<team>.atlassian.net).",
    "verified_against_docs": "2026-06-14"
  },
  "mcp": {
    "server_key": "atlassian",
    "command": "npx",
    "args": ["-y", "mcp-atlassian"],
    "env_map": {
      "ATLASSIAN_URL": "${ATLASSIAN_URL}",
      "ATLASSIAN_EMAIL": "${ATLASSIAN_EMAIL}",
      "ATLASSIAN_API_TOKEN": "${ATLASSIAN_API_TOKEN}"
    }
  },
  "validate": {
    "method": "GET",
    "url": "${ATLASSIAN_URL}/rest/api/3/myself",
    "auth": "basic:${ATLASSIAN_EMAIL}:${ATLASSIAN_API_TOKEN}",
    "headers": { "Accept": "application/json" },
    "expect": { "status": 200, "json_has": ["accountId"] },
    "identity": { "json_path": "displayName", "label": "You" },
    "instance_check": { "json_path": "accountId", "label": "Account" }
  }
}
