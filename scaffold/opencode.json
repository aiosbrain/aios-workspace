{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "aios-orchestrator",
  "instructions": [
    ".claude/rules/access-control.md",
    ".claude/rules/bookkeeping.md",
    ".claude/rules/communications.md",
    ".claude/rules/decision-log.md",
    ".claude/rules/documents.md",
    ".claude/rules/frontmatter.md",
    ".claude/rules/hours.md",
    ".claude/rules/interlinking.md",
    ".claude/rules/legal.md",
    ".claude/rules/publishing.md",
    ".claude/rules/scheduling.md",
    ".claude/rules/hermes-skills.md",
    ".claude/rules/workflow.md",
    ".claude/rules/git-workflow.md",
    ".claude/memory/instincts.md"
  ],
  "references": {
    "0-context": "0-context/",
    "1-inbox": "1-inbox/",
    "2-work": "2-work/",
    "3-log": "3-log/",
    "4-shared": "4-shared/",
    "rules": ".claude/rules/",
    "skills": ".claude/skills/"
  },
  "plugin": ["./.opencode/plugins/aios-instincts.ts"],
  "permission": {
    "bash": {
      "aios *": "allow",
      "git *": "allow",
      "node scripts/*": "allow",
      "node bin/*": "allow",
      "*": "ask"
    },
    "external_directory": "ask",
    "doom_loop": "deny",
    "edit": {
      "5-personal/*": "deny",
      "engagement-admin/*": "deny",
      "bookkeeping/*": "deny",
      "entities/*": "deny",
      "insurance/*": "deny",
      "business-administration/*": "deny",
      "research/*": "deny",
      "portfolio/*": "deny",
      "partnerships/*": "deny",
      "templates/*": "deny",
      "ops/*": "deny",
      "*": "allow"
    }
  }
}
