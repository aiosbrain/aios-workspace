# AIOS Team Brain connection — restricted YAML subset (flat scalars + string
# lists only; no nesting beyond one level of lists). Parsed by scripts/aios.mjs.
#
# Leave brain_url empty to run fully offline/standalone — every other part of
# this workspace works without a Team Brain.
version: 1
brain_url: "{{BRAIN_URL}}"
team_id: "{{TEAM_ID}}"

# NAME of the environment variable holding your API key — never the key itself.
api_key_env: AIOS_API_KEY

# Agent runtime that drives this workspace — Bring Your Own Agent (see
# docs/byoa.md). The runtime is independent of which model/provider answers
# (cloud vs local); the two compose freely.
#   claude-code (default) | hermes | openclaw | codex | opencode | claude-api
# Default keeps existing workspaces unchanged.
agent_runtime: claude-code
# Optional hints a runtime adapter may use; leave blank for the runtime's own
# defaults. Endpoint/model normally live with the runtime, not here.
agent_model: ""
agent_base_url: ""
# Cockpit personality — a style-only voice appended to the agent's system prompt.
# One of the files in .claude/personalities/ (aios | operator | coach | analyst).
# Switchable in the cockpit's Settings; never overrides rules/CLAUDE.md/skills.
agent_personality: "aios"

# Background memory reviewer (cockpit, claude-code runtime only): after each turn a
# fast model conservatively saves durable facts to .claude/memory/USER.md /
# WORKSPACE.md (💾 notice + undo; takes effect next session). on | off. Toggle in
# Settings. Secrets are never sent to the reviewer or written.
memory_review: on

# Which access tiers may leave this machine.
#   private  → never syncs (canonical: admin; hard-failed if listed here)
#   team     → shared with your team via the brain
#   client   → consultant outward tier   ┐ both canonical: external
#   company  → employee outward tier      ┘
sync_tiers:
  - team
  - {{OUTWARD_TIER}}

# Paths considered for sync (relative to workspace root). Files still need an
# `access:` frontmatter tier within sync_tiers to actually push — files with
# no access tier are blocked by default (default-deny).
sync_include:
  - 0-context
  - 2-work
  - 3-log/decision-log.md
  - 3-log/tasks.md
  - 3-log/ai-spend.md
  - 4-shared
  - .claude/memory
sync_exclude:
  - 5-personal

# Identity override (optional). Resolution order:
#   $AIOS_MEMBER → this field → `git config aios.member` → git user.name
member: ""

# How you work: consultant | employee
context: {{CONTEXT}}
