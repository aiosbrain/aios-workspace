# Copy to .env (gitignored). Never commit real values.

# Team Brain API key — issued per member in the brain's admin UI, shown once.
AIOS_API_KEY=

# Your member identity (optional — defaults to `git config aios.member`,
# then git user.name). Must match a name in project.yaml members.
AIOS_MEMBER=

# Override brain_url from aios.yaml (optional; useful for local development).
AIOS_BRAIN_URL=

# Anthropic API key for the local GUI (gui/) and Claude-powered tooling.
ANTHROPIC_API_KEY=
