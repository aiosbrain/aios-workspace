{
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/hooks/asks-capture.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/hooks/asks-capture.mjs"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/hooks/session-pulse.mjs"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/hooks/aios-sync-nudge.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/hooks/instinct-observe.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "AskUserQuestion|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/hooks/decision-capture.mjs"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/hooks/maturity-capture.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/hooks/maturity-brief.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/hooks/asks-capture.mjs"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/hooks/maturity-nudge.mjs",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
