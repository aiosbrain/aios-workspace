#!/usr/bin/env bash
#
# pre-commit-primary-guard — block feature commits in the PRIMARY checkout.
#
# AIOS requires every agent to do its work in a dedicated `git worktree`
# (`aios worktree add <feat/branch>`), NEVER as a branch committed in the
# primary checkout. Automated harnesses (e.g. oh-my-opencode / Codex) have
# been observed doing `git checkout -b <feature>` in the primary checkout and
# committing there — stranding the primary on a feature branch and producing
# duplicate PRs.
#
# This hook makes that structurally loud: a commit is BLOCKED when
#   (a) the working copy is the PRIMARY checkout (not a linked worktree), AND
#   (b) the current branch is NOT the default branch (`main`).
#
# It is a NO-OP inside a legitimate linked worktree (where feature work belongs)
# and on `main` in the primary (for the rare intentional hotfix — though even
# that is gated below on an explicit override for non-main branches only).
#
# Override for a genuinely intentional primary-checkout feature commit:
#   AIOS_ALLOW_PRIMARY_COMMIT=1 git commit ...
#
# Installed to `.git/hooks/pre-commit` by `scripts/install-primary-commit-guard.sh`.
# git hooks are NOT version-controlled; this tracked source is the durable copy.
# The installer chains any pre-existing pre-commit hook (e.g. the NDA leak gate)
# to `.git/hooks/pre-commit.chained`, which this guard execs on success.

set -euo pipefail

DEFAULT_BRANCH="main"

# ── Detect PRIMARY vs linked WORKTREE ──────────────────────────────────────
# In the primary checkout, the git dir IS the common git dir.
# In a linked worktree, the git dir is `<common>/worktrees/<name>` — different.
git_dir="$(git rev-parse --absolute-git-dir 2>/dev/null || true)"
common_dir="$(git rev-parse --git-common-dir 2>/dev/null || true)"

# Normalize the common dir to an absolute path (it can be reported relative,
# e.g. ".git", when invoked from the primary working tree root).
if [[ -n "$common_dir" && "$common_dir" != /* ]]; then
  common_dir="$(cd "$common_dir" 2>/dev/null && pwd || echo "$common_dir")"
fi

is_primary=0
if [[ -n "$git_dir" && "$git_dir" == "$common_dir" ]]; then
  is_primary=1
fi

if [[ "$is_primary" == "1" ]]; then
  branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo HEAD)"
  if [[ "$branch" != "$DEFAULT_BRANCH" ]]; then
    if [[ "${AIOS_ALLOW_PRIMARY_COMMIT:-}" == "1" ]]; then
      echo "[aios] AIOS_ALLOW_PRIMARY_COMMIT=1 set — allowing commit on '$branch' in the primary checkout." >&2
    else
      cat >&2 <<EOF

┌─────────────────────────────────────────────────────────────────────────────┐
│  AIOS worktree guard: commit BLOCKED in the PRIMARY checkout                 │
└─────────────────────────────────────────────────────────────────────────────┘

You are committing to branch '$branch' inside the PRIMARY checkout:
  $(git rev-parse --show-toplevel 2>/dev/null)

AIOS requires feature work to live in a dedicated git worktree, never on a
branch committed in the primary checkout (it collides with concurrent work and
produces duplicate PRs). Do this instead:

  aios worktree add $branch
  cd ../$(basename "$(git rev-parse --show-toplevel 2>/dev/null)")-worktrees/${branch//\//-}
  # then commit there

If this really is an intentional primary-checkout commit (rare hotfix), re-run:

  AIOS_ALLOW_PRIMARY_COMMIT=1 git commit ...

EOF
      exit 1
    fi
  fi
fi

# ── Chain to any pre-existing pre-commit hook (e.g. the NDA leak gate) ──────
chained="$(git rev-parse --git-path hooks/pre-commit.chained 2>/dev/null || true)"
if [[ -n "$chained" && -x "$chained" ]]; then
  exec "$chained" "$@"
fi

exit 0
