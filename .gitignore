.DS_Store
node_modules/
__pycache__/
*.pyc
.venv/
.aios/
.claude/worktrees/
.env
.env.local
gui/.sessions/
gui/client/dist/
dist/
coverage/
gui/client/coverage/
test/ux/evidence/
.aios/

.env.keys
# Root-level scratch exports from aios tools (not source of truth; regenerated)
/.aio-*.md
# Confidential leak-gate term set — local only, never commit (see scripts/leak-gate-terms.example.sh)
leak-gate-terms.sh
**/leak-gate-terms.sh
.aios-nda/
# Local spec-eval run logs (not source of truth)
docs/pre-ship/.spec-eval-results.tsv
docs/pre-ship/.spec-fix-log.txt

# Worktree hydration artifacts (created by scripts/link-worktree-env.sh in every
# worktree) — machine-local config, must never be committed.
/.opencode/*
!/.opencode/plugins/
/.opencode/plugins/*
!/.opencode/plugins/aios-bugbot.mjs
!/.opencode/opencode.json
/opencode.json
/.mcp.json

# Agent runtime session state (omo run-continuation records) — written into the
# repo root on every session; machine-local, never source of truth.
.omo/
