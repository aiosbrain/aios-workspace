{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AIOS Workspace",
  "version": "0.1.0",
  "identifier": "dev.aios.workspace",
  "build": {
    "frontendDist": "../gui/client/dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../gui/server": "gui/server",
      "../gui/client/dist": "gui/client/dist",
      "../scripts": "scripts",
      "../validation": "validation",
      "../scaffold": "scaffold",
      "../node_modules": "node_modules"
    }
  }
}
