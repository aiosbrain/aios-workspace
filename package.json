{
  "name": "aios-workspace",
  "version": "0.7.0",
  "private": true,
  "description": "Agent-native operating system for an individual contributor: governed workspace scaffold, multi-agent harnesses with rubric-gated self-correction, AIOS Team Brain sync client, and a local GUI.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "aios": "scripts/aios.mjs"
  },
  "workspaces": [
    "gui/server",
    "gui/client"
  ],
  "scripts": {
    "help": "node scripts/npm-menu.mjs",
    "postinstall": "node scripts/ensure-loop-built.mjs && node scripts/gui-runtime-preflight.mjs --warn-only && node scripts/postinstall-banner.mjs",
    "gui": "node scripts/run-gui.mjs",
    "gui:build": "npm run build --workspace gui/client",
    "gui:preflight": "node scripts/gui-runtime-preflight.mjs",
    "aios": "dotenvx run -- node scripts/aios.mjs",
    "gen:catalog": "node scripts/gen-catalog.mjs",
    "build:loop": "tsc -p tsconfig.json",
    "check:context": "node scripts/check-context.mjs",
    "check:docs": "node scripts/check-docs-drift.mjs",
    "check:domains": "node scripts/check-domain-isolation.mjs",
    "check:size": "node scripts/check-file-size.mjs",
    "check:v1-linear": "node scripts/check-v1-linear-drift.mjs",
    "check:inbox-audit": "node scripts/inbox-redaction-lint.mjs",
    "eval:transcripts": "node evals/transcript-extraction/extraction-eval.mjs",
    "pr:backlog": "node scripts/pr-backlog-report.mjs",
    "lint": "eslint scripts validation gui/server gui/client/src test",
    "lint:fix": "eslint scripts validation gui/server gui/client/src test --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "setup": "npm ci && npm run gui:build",
    "test": "npm run test:prepare && npm run test:node && npm run test:client && npm run test:rust",
    "test:prepare": "node scripts/ensure-native-abi.mjs && npm run build:loop && npm run check:domains && npm run check:size && npm run check:inbox-audit",
    "test:node": "node scripts/ensure-loop-built.mjs && node scripts/test-suite.mjs",
    "test:node:list": "node scripts/test-suite.mjs --list",
    "test:client": "npm run test --workspace gui/client",
    "test:rust": "npm run gui:build && cargo test --manifest-path src-tauri/Cargo.toml --locked",
    "test:install-smoke": "node scripts/test-suite.mjs --only=test/gui-runtime-production-install.test.mjs --live-install --concurrency=1",
    "test:gateway-contracts": "node --test test/contract-conformance.test.mjs test/gateway-contract.test.mjs",
    "test:gateway-approval-contracts": "node --test test/gateway-contract.test.mjs test/gateway-approval-contract.test.mjs",
    "test:ux": "node test/ux/run-ux.mjs",
    "test:coverage": "npm run test:prepare && node scripts/run-coverage.mjs && node scripts/check-coverage.mjs",
    "test:mutation": "node scripts/run-mutation.mjs",
    "test:mutation:nightly": "node scripts/run-mutation.mjs --nightly",
    "app:dev": "npm run gui:preflight && npm run gui:build && dotenvx run -- tauri dev",
    "app:build": "npm run gui:preflight && npm run gui:build && tauri build",
    "app:icon": "tauri icon"
  },
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=22 <23"
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "^0.28.1",
    "@dotenvx/dotenvx": "^1.52.0",
    "@eslint/js": "^9.16.0",
    "@tauri-apps/cli": "^2.11.4",
    "@types/better-sqlite3": "^7.6.11",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.10.0",
    "c8": "^11.0.0",
    "eslint": "^9.16.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^15.13.0",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@aios-alpha/design": "^0.3.0",
    "@anthropic-ai/claude-agent-sdk": "^0.3.179",
    "@anthropic-ai/sdk": "^0.109.0",
    "@clack/prompts": "^1.7.0",
    "better-sqlite3": "^11.10.0"
  }
}
